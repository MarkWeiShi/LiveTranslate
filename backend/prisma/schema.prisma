// LinkU MVP — SQLite schema (zero-infra). Arrays stored as JSON strings, enums as String.
// To go to production: switch provider to "postgresql", re-migrate, restore native arrays/enums.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  helloTalkUserId    String   @unique // = profile.sub; idempotent re-login (AC-AUTH-2)
  displayName        String
  avatarUrl          String?
  nativeLanguage     String // translation target language
  learningLanguages  String   @default("[]") // JSON string array
  languageLevel      String? // A1..C2
  gender             String // MALE|FEMALE|OTHER
  region             String?
  timezone           String?
  bio                String?
  interests          String   @default("[]") // JSON string array
  realPersonVerified Boolean  @default(false)
  trustScore         Int      @default(50)
  intent             String   @default("SOCIAL") // SOCIAL|DEEP|LANG_SOCIAL
  createdAt          DateTime @default(now())
  wallet             Wallet?
}

model Wallet {
  userId             String    @id
  user               User      @relation(fields: [userId], references: [id])
  diamonds           Int       @default(0) // 消费币（充值得到，用于送礼）
  earnings           Int       @default(0) // 收礼收益（可提现）
  trialSecondsLeft   Int       @default(420)
  subscriptionTier   String    @default("NONE") // NONE|WEEKLY|MONTHLY
  subscriptionExpiry DateTime?
}

// 提现申请
model Withdrawal {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  status    String   @default("PENDING") // PENDING|PAID|REJECTED
  createdAt DateTime @default(now())

  @@index([userId])
}

model CallSession {
  id            String    @id @default(cuid())
  callerId      String
  calleeId      String
  mode          String // VIDEO|VOICE
  status        String // RINGING|ACTIVE|ENDED|DECLINED|MISSED
  translationOn Boolean   @default(true)
  startedAt     DateTime?
  endedAt       DateTime?
  durationSec   Int       @default(0)
  translatedSec Int       @default(0)
  createdAt     DateTime  @default(now())

  @@index([callerId])
  @@index([calleeId])
}

model Gift {
  id        String   @id @default(cuid())
  callId    String
  fromId    String
  toId      String
  giftType  String
  diamonds  Int
  createdAt DateTime @default(now())
}

model Friendship {
  id        String   @id @default(cuid())
  userIdA   String
  userIdB   String
  status    String   @default("ACCEPTED") // PENDING|ACCEPTED
  createdAt DateTime @default(now())

  @@unique([userIdA, userIdB])
}

model Block {
  id            String   @id @default(cuid())
  userId        String
  blockedUserId String
  createdAt     DateTime @default(now())

  @@unique([userId, blockedUserId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  targetId   String
  callId     String?
  reason     String
  detail     String?
  createdAt  DateTime @default(now())
}

model RiskEvent {
  id        String   @id @default(cuid())
  userId    String
  callId    String?
  type      String
  score     Int
  snippet   String?
  createdAt DateTime @default(now())
}

// 多渠道获客归因（telegram / x / messenger / instagram ...）。userId 留待注册闭环回填。
model Attribution {
  id         String   @id @default(cuid())
  source     String? // 来源原文（twitter / fb / ig ...）
  channel    String // 归一化渠道：telegram|x|messenger|instagram|whatsapp|web|direct
  externalId String? // telegram user id（字符串存储）
  username   String?
  startParam String? // telegram start_param（兼容保留）
  ref        String? // 统一 referral（telegram start_param 或 utm ref）—裂变归因
  campaign   String? // utm_campaign
  medium     String? // utm_medium
  userId     String? // 注册后回填（当前可空）
  raw        String? // 原始 initData / 落地 URL，便于审计
  verified   Boolean  @default(false) // initData HMAC 是否通过（仅 telegram 真实模式）
  createdAt  DateTime @default(now())

  @@index([channel])
}

// 转化漏斗事件：land(落地) → signup(注册) → activate(首通/首条互动)。按渠道聚合。
model FunnelEvent {
  id        String   @id @default(cuid())
  channel   String
  ref       String?
  stage     String // land | signup | activate
  userId    String?
  createdAt DateTime @default(now())

  @@index([channel, stage])
}

// 成长体系：个人积分/等级
model GrowthProfile {
  userId    String   @id
  xp        Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt
}

// 跨国 CP 亲密度（双人；userLo<userHi 归一化）
model Bond {
  id        String   @id @default(cuid())
  userLo    String
  userHi    String
  intimacy  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userLo, userHi])
}

// 家族战
model Family {
  id        String   @id @default(cuid())
  name      String
  score     Int      @default(0)
  createdAt DateTime @default(now())
}

model FamilyMember {
  id           String @id @default(cuid())
  familyId     String
  userId       String
  contribution Int    @default(0)

  @@unique([familyId, userId])
  @@index([userId])
}
