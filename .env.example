# ============================================================
# LinkU MVP environment — all third-party deps default to MOCK.
# Copy to backend/.env (backend) and app/.env (Expo) as needed.
# ============================================================

# ---- Backend (backend/.env) ----
NODE_ENV=development
PORT=3000

# Auth: mock | hellotalk
AUTH_PROVIDER=mock
HELLOTALK_ISSUER=
HELLOTALK_CLIENT_ID=
HELLOTALK_CLIENT_SECRET=
HELLOTALK_REDIRECT_URI=
JWT_SECRET=dev_only_change_me_in_prod
JWT_EXPIRES_IN=7d

# Media transport: mock | livekit
MEDIA_PROVIDER=mock
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Translation engine: mock | gemini
TRANSLATION_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-3.5-live-translate-preview
# real Python agent posts translatedSec to this guarded ingress
AGENT_INGRESS_TOKEN=dev_agent_token

# Payments: mock | revenuecat
PAYMENT_PROVIDER=mock
REVENUECAT_API_KEY=

# Presence/KV store: memory | redis
STORE_DRIVER=memory
REDIS_URL=

# Database (SQLite for MVP; switch provider to postgresql for prod)
DATABASE_URL=file:./dev.db

# Optional cross-product blacklist sync (empty = no-op)
RISK_SYNC_WEBHOOK=

# Test/dev tuning (do NOT set in prod): override 1s tick / 420s trial for fast tests
TICK_INTERVAL_MS=
TRIAL_SECONDS_OVERRIDE=

# ---- Expo app (app/.env) ----
EXPO_PUBLIC_API_BASE=http://localhost:3000
EXPO_PUBLIC_WS_BASE=http://localhost:3000
EXPO_PUBLIC_TRANSPORT=mock
EXPO_PUBLIC_AUTH=mock
EXPO_PUBLIC_MOCK_MEDIA=webrtc
EXPO_PUBLIC_MOCK_TTS=off
